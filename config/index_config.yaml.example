# Document index configuration for local-graph-rag.
# Copy this file to config/index_config.yaml and customize it for your setup.
#
# Paths are container paths — host directories are mounted via docker-compose.
# See .env.example for the corresponding host-path variables (NEXTCLOUD_PATH, CODE_PATH).
#
# /app/documents/Nextcloud  ← mounted from NEXTCLOUD_PATH in your .env
# /app/documents/Code       ← mounted from CODE_PATH in your .env

index_paths:

  # Add one entry per subdirectory you want to index under your Nextcloud mount.
  # Remove or replace these examples with your actual folder names.
  - path: /app/documents/Nextcloud/YourFolder
    recursive: true

  # - path: /app/documents/Nextcloud/AnotherFolder
  #   recursive: true

  - path: /app/documents/Code
    recursive: true
    exclude_dirs:
      - .git
      - .venv
      - venv
      - __pycache__
      - node_modules
      - .npm
      - .yarn
      - .pytest_cache
      - .mypy_cache
      - .ruff_cache
      - .tox
      - .cache
      - build
      - dist
      - target
      - out
      - .next
      - .codex
      - .idea
      - .vscode
      - wandb
      - mlruns
      - checkpoints


allowed_extensions:
  - .md
  - .txt
  - .py
  - .js
  - .ts
  - .tsx
  - .jsx
  - .json
  - .yaml
  - .yml
  - .toml
  - .go
  - .rs


ignore_patterns:

  # Version control
  - .git
  - .svn
  - .hg

  # Python
  - __pycache__
  - .venv
  - venv
  - .pytest_cache
  - .mypy_cache
  - .tox
  - "*.egg-info"

  # Node
  - node_modules
  - .npm
  - .yarn

  # Build outputs
  - build
  - dist
  - target
  - out
  - .next
  - "*.min.js"

  # IDE
  - .idea
  - .vscode
  - .claude

  # Secrets and credentials
  - .env
  - .env.*
  - .aws
  - .azure
  - .gnupg
  - .ssh
  - "*.key"
  - "*.pem"
  - "*.p12"
  - "*.pfx"
  - id_rsa
  - id_dsa
  - id_ecdsa
  - id_ed25519

  # OS junk
  - .DS_Store
  - Thumbs.db

  # ML artifacts
  - wandb
  - mlruns
  - checkpoints

  # Binary and media
  - "*.png"
  - "*.jpg"
  - "*.jpeg"
  - "*.gif"
  - "*.pdf"
  - "*.zip"
  - "*.tar"
  - "*.gz"
  - "*.mp4"
  - "*.exe"
  - "*.so"
  - "*.dylib"
