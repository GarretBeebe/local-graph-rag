# Copy this file to .env and fill in the required values.
#
# Linux / macOS:        /home/yourname/...
# Windows (Git Bash):   /c/Users/YourName/...
# Windows (PowerShell): C:/Users/YourName/...

# Host paths mounted into the container as document sources. Required.
# These map to /app/documents/Nextcloud and /app/documents/Code inside the
# container — matching the paths in config/index_config.yaml.
NEXTCLOUD_PATH=
CODE_PATH=

# Qdrant API key — required. Generate with: openssl rand -hex 32
QDRANT_API_KEY=

# API key for OpenAI-compatible clients. Leave blank to disable.
# Must be at least 32 characters when set. Generate with: openssl rand -hex 32
# API_KEY=

# Network binding for the API container.
# Default 127.0.0.1 is safe for local-only access.
# Set to 0.0.0.0 (or your LAN interface IP) when a reverse proxy on a separate
# host needs to reach this container (e.g. Caddy on another machine).
# API_BIND_HOST=127.0.0.1

# Override host port if 8000 is already in use.
# API_PORT=8000

# Trusted reverse-proxy IPs. Set to your Caddy/nginx host IP so that
# X-Forwarded-For and X-Forwarded-Proto headers are trusted by the middleware.
# TRUSTED_PROXY_IPS=192.168.68.69

# Allowed origins for cross-origin requests (comma-separated), needed for
# browser/webview-based OpenAI-compatible clients (e.g. Chatbox mobile).
# Use * to allow any origin if auth is a Bearer token or session cookie
# (CORSMiddleware allow_credentials=False, so cookies aren't sent cross-origin
# anyway). NOT allowed when ALLOW_INSECURE_LOCALONLY=true — with auth disabled,
# CORS_ORIGINS=* would let any website read your indexed corpus.
# CORS_ORIGINS=*

# Override if Ollama is not running on the default port.
# OLLAMA_BASE_URL=http://localhost:11434

# Full Qdrant URL — overrides QDRANT_HOST/QDRANT_PORT when set.
# Use this to point at a remote Qdrant over HTTPS:
# QDRANT_URL=https://your-qdrant-host:6333

# LLM models (all default to the values shown).
# EXTRACT_MODEL=qwen2.5:3b
# SUMMARIZE_MODEL=qwen2.5:7b
# GEN_MODEL=qwen2.5:14b

# Context window size for Ollama generation.
# OLLAMA_NUM_CTX=16384

# Max concurrent Ollama generation calls. CPU-only systems should keep this at 1.
# GENERATION_CONCURRENCY_LIMIT=1

# Graph retrieval tuning.
# ENTITY_RETRIEVAL_K=5
# ENTITY_NEIGHBORHOOD_HOPS=2
# COMMUNITY_RETRIEVAL_N=5
