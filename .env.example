# Copy this file to .env and fill in the required values.
#
# Windows (WSL2) paths: /mnt/c/Users/YourName/Documents
# Linux paths:          /home/yourname/documents

# Path to the directory of documents to index. Required.
DOCS_PATH=

# Qdrant API key — required. Generate with: openssl rand -hex 32
QDRANT_API_KEY=

# Override host port if 8000 is already in use.
# API_PORT=8001

# Override if Ollama is not running on the default port.
# OLLAMA_BASE_URL=http://localhost:11434

# LLM models (all default to the values shown).
# EXTRACT_MODEL=qwen2.5:3b
# SUMMARIZE_MODEL=qwen2.5:7b
# GEN_MODEL=qwen2.5:14b

# Context window size for Ollama generation.
# OLLAMA_NUM_CTX=16384

# Max concurrent Ollama generation calls. CPU-only systems should keep this at 1.
# GENERATION_CONCURRENCY_LIMIT=1

# Graph retrieval tuning.
# ENTITY_RETRIEVAL_K=5
# ENTITY_NEIGHBORHOOD_HOPS=2
# COMMUNITY_RETRIEVAL_N=5
